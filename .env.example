# ============================================================
# Defending the Hidden — Environment Configuration Template
# ============================================================
# Copy this file to `.env` in the defenceAgent/ directory
# and fill in your own credentials before running.
#
#   cp .env.example defenceAgent/.env
#
# NEVER commit the actual .env file — it contains secret keys.
# ============================================================


# ------------------------------------------------------------
# DashScope / Alibaba Cloud API Key
# Required for all Qwen model calls (embedding, reasoning, VL)
# Get yours at: https://dashscope.aliyuncs.com/
# ------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# Defense & Debate Agent Models
#
# DEF_MLLM_MODEL   : multimodal model used by the defense agents
# DEF_TEXT_MODEL   : text-only reasoning model (Attack/Judge agents)
# DEF_IMAGE_MODEL  : dedicated image analysis model
# ASR_JUDGE_MODEL  : lightweight model for ASR evaluation scoring
#
# Recommended defaults (replace with models available to you):
# ------------------------------------------------------------
DEF_MLLM_MODEL=qwen-vl-plus
DEF_TEXT_MODEL=qwen3-vl-plus
DEF_IMAGE_MODEL=qwen3-vl-plus
ASR_JUDGE_MODEL=qwen-flash


# ------------------------------------------------------------
# OpenAI-Compatible API Endpoint
# Used by MM-Vet official grading and any GPT-4-based judge.
# Set OPENAI_API_BASE to your gateway if you use a proxy.
# ------------------------------------------------------------
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# Doubao / Volcano Engine API Key
# Required only if you evaluate against Doubao-1.5-vision-pro.
# Get yours at: https://www.volcengine.com/product/ark
# ------------------------------------------------------------
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
